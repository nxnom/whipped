{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@runtime-contract": ["../src/core/api-contract.ts"],
      "@runtime-api": ["../src/api/index.ts"],
      "@runtime-validation/*": ["../src/core/validation/*"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
