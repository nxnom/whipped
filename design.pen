                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Appended to all agents (dev, code review, QA, assistant). Use for tech stack, project goals, or any context all agents should know.",
                      "fontFamily": "Inter",
                      "fontSize": 12,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "frame",
                      "id": "gIA1O",
                      "width": "fill_container",
                      "height": 180,
                      "fill": "#0c0c0f",
                      "cornerRadius": 8,
                      "stroke": "#2a2a35",
                      "strokeWidth": 1,
                      "strokeAlignment": "inner",
                      "layout": "vertical",
                      "padding": [
                        14,
                        16
                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "ywmND",
                          "fill": "#c0c0d0",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Tech stack: Next.js 15, TypeScript 5.6, Postgres 16, Drizzle ORM\nHosting: Vercel (frontend), Railway (backend)\nWebsite: https://app.Whipped.dev\n\nGoals:\n- Keep bundle size under 200kb\n- Follow REST conventions for all API routes\n- Use server components by default\n- All database queries must use parameterized statements",
                          "lineHeight": 1.5,
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        }
                      ]
                    }
